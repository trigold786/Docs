│  │      connectionPool:                                               │   │
│  │        tcp:                                                         │   │
│  │          maxConnections: 100                                       │   │
│  │      outlierDetection:                                             │   │
│  │        consecutive5xxErrors: 5                                     │   │
│  │        interval: 30s                                                │   │
│  │        baseEjectionTime: 30s                                        │   │
│  │                                                                     │   │
