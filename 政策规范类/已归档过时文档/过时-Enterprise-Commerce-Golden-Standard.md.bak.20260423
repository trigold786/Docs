│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
│  【Circuit Breaker配置】                                                    │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │  Resilience4j配置:                                                  │   │
│  │                                                                     │   │
│  │  circuitbreaker:                                                   │   │
│  │    instances:                                                      │   │
│  │      mfaService:                                                  │   │
│  │        slidingWindowSize: 10    # 滑动窗口10次调用                 │   │
│  │        failureRateThreshold: 50  # 50%失败率阈值                   │   │
│  │        waitDurationInOpenState: 30s  # 30秒熔断持续时间           │   │
│  │        permittedNumberOfCallsInHalfOpenState: 3  # 半开状态3次   │   │
│  │        slidingWindowType: COUNT_BASED                              │   │
│  │                                                                     │   │
│  │  retry:                                                            │   │
│  │    instances:                                                      │   │
│  │      defaultRetry:                                                 │   │
│  │        maxAttempts: 3                                              │   │
│  │        waitDuration: 500ms                                         │   │
│  │        enableExponentialBackoff: true                              │   │
│  │        exponentialBackoffMultiplier: 2                             │   │
│  │                                                                     │   │
│  │  timelimiter:                                                      │   │
│  │    instances:                                                      │   │
│  │      default:                                                      │   │
│  │        timeoutDuration: 10s                                        │   │
│  │        cancelRunningFuture: true                                   │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
│  【降级策略】                                                                │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │                                                                     │   │
│  │  降级级别1：MFA服务降级                                              │   │
│  │  - 触发：MFA验证连续失败或服务超时                                   │   │
│  │  - 动作：跳过MFA，发送安全告警，标记账户为"待验证"                   │   │
│  │                                                                     │   │
│  │  降级级别2：权限服务降级                                             │   │
│  │  - 触发：权限检查超时或失败                                          │   │
│  │  - 动作：拒绝访问（默认安全），记录审计日志                          │   │
│  │                                                                     │   │
│  │  降级级别3：安全审计降级                                             │   │
│  │  - 触发：审计系统不可用                                              │   │
│  │  - 动作：写入本地文件队列，恢复后重放                                │   │
│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
│  【必选/可选】                                                               │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │                                                                     │   │
│  │  MUST：身份认证（MFA）、风控安全（欺诈检测/爬虫识别）                │   │
│  │  SHOULD：合规管理（GDPR/PCI-DSS）、审计日志                         │   │
│  │  MAY：生物识别、设备认证                                             │   │
│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
└─────────────────────────────────────────────────────────────────────────────┘
```

