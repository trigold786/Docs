│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │                                                                     │   │
│  │  【VirtualService配置】                                              │   │
│  │  apiVersion: networking.istio.io/v1beta1                           │   │
│  │  kind: VirtualService                                               │   │
│  │  spec:                                                             │   │
│  │    hosts:                                                          │   │
│  │    - service-name                                                  │   │
│  │    http:                                                           │   │
│  │    - route:                                                        │   │
│  │      - destination:                                                │   │
│  │          host: service-name                                        │   │
│  │      retries:                                                      │   │
│  │        attempts: 3                                                 │   │
│  │        perTryTimeout: 10s                                          │   │
│  │      timeout: 30s                                                 │   │
│  │                                                                     │   │
│  │  【DestinationRule熔断配置】                                         │   │
│  │  apiVersion: networking.istio.io/v1beta1                           │   │
