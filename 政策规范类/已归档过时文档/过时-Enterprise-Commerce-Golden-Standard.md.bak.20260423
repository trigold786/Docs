│  ├─────────────────────────────────────────────────────────────────────┤   │
│  │  SEC-001 │ 敏感数据加密存储               │ MUST    │ 安全审查         │   │
│  │  SEC-002 │ 敏感数据传输加密（TLS）        │ MUST    │ 安全审查         │   │
│  │  SEC-003 │ 认证授权机制完善               │ MUST    │ 安全审查         │   │
│  │  SEC-004 │ 会话管理安全                   │ MUST    │ 安全审查         │   │
│  │  SEC-005 │ SQL注入防护                   │ MUST    │ 安全扫描         │   │
│  │  SEC-006 │ XSS防护                       │ MUST    │ 安全扫描         │   │
│  │  SEC-007 │ CSRF防护                      │ MUST    │ 安全扫描         │   │
│  │  SEC-008 │ 接口限流防刷                  │ MUST    │ 设计审查         │   │
│  │  SEC-009 │ 安全日志完整                   │ MUST    │ 运维审查         │   │
│  │  SEC-010 │ 密钥管理使用KMS               │ MUST    │ 安全审查         │   │
│  │  SEC-011 │ 依赖安全漏洞扫描               │ MUST    │ CI/CD检查        │   │
│  │  SEC-012 │ 容器安全扫描                   │ MUST    │ CI/CD检查        │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
│  【数据分类分级】                                                            │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │                                                                     │   │
│  │  等级    │ 定义              │ 示例                    │ 保护要求     │   │
│  │  ────────┼──────────────────┼────────────────────────┼───────────  │   │
│  │  L4 绝密 │ 影响公司生死      │ 支付密钥、用户密码明文  │ 最高级别加密  │   │
│  │  L3 机密 │ 影响公司核心利益  │ 用户银行卡、身份证      │ 强加密+审计  │   │
│  │  L2 敏感 │ 影响用户体验      │ 用户手机号、地址        │ 中等加密     │   │
│  │  L1 内部 │ 内部使用          │ 业务数据、配置          │ 基本保护     │   │
│  │  L0 公开 │ 可公开            │ 商品信息、公开文章      │ 无特殊要求   │   │
│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
└─────────────────────────────────────────────────────────────────────────────┘
```

