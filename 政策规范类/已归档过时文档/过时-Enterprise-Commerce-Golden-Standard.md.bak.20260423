│  │  spec:                                                            │   │
│  │    scaleTargetRef:                                                │   │
│  │      apiVersion: apps/v1                                         │   │
│  │      kind: Deployment                                             │   │
│  │      name: service-name                                           │   │
│  │    minReplicas: 3                                                 │   │
│  │    maxReplicas: 100                                               │   │
│  │    metrics:                                                      │   │
│  │    - type: Resource                                               │   │
│  │      resource:                                                   │   │
│  │        name: cpu                                                 │   │
│  │        target:                                                   │   │
│  │          type: Utilization                                        │   │
│  │          averageUtilization: 70                                  │   │
