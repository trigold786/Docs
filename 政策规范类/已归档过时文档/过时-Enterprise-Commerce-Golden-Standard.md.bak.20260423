### 7.2 服务契约标准

```
┌─────────────────────────────────────────────────────────────────────────────┐
│                         服务契约标准                                          │
├─────────────────────────────────────────────────────────────────────────────┤
│                                                                             │
│  【接口定义规范】                                                            │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │                                                                     │   │
│  │  【REST接口】                                                         │   │
│  │                                                                     │   │
│  │  请求格式：                                                           │   │
│  │  POST /api/v1/resource                                              │   │
│  │  Content-Type: application/json                                     │   │
│  │  Authorization: Bearer <token>                                       │   │
│  │                                                                     │   │
│  │  {                                                                   │   │
│  │    "field1": "value1",                                             │   │
│  │    "field2": "value2"                                               │   │
│  │  }                                                                   │   │
│  │                                                                     │   │
│  │  响应格式：                                                          │   │
│  │  {                                                                   │   │
│  │    "code": 0,                    // 0=成功，非0=失败                │   │
│  │    "message": "success",         // 错误信息                        │   │
│  │    "data": {                     // 业务数据                        │   │
│  │      "id": "123",                                                 │   │
│  │      "name": "resource"                                           │   │
│  │    },                                                               │   │
│  │    "request_id": "uuid"        // 请求追踪ID                       │   │
│  │  }                                                                   │   │
│  │                                                                     │   │
│  │  【gRPC接口】                                                        │   │
│  │                                                                     │   │
│  │  syntax = "proto3";                                                │   │
│  │  package service.v1;                                               │   │
│  │                                                                     │   │
│  │  service ResourceService {                                          │   │
│  │    rpc CreateResource(CreateRequest) returns (CreateResponse);     │   │
│  │    rpc GetResource(GetRequest) returns (GetResponse);               │   │
│  │  }                                                                   │   │
│  │                                                                     │   │
│  │  message CreateRequest {                                            │   │
│  │    string name = 1;                                                │   │
│  │  }                                                                   │   │
│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
│  【服务契约检查表】                                                          │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │  标准编号 │ 标准名称                     │ 要求级别 │ 验证方法         │   │
│  ├─────────────────────────────────────────────────────────────────────┤   │
│  │  SC-001  │ 接口文档完整                   │ MUST    │ 文档审查         │   │
│  │  SC-002  │ 接口版本管理                   │ MUST    │ 代码审查         │   │
│  │  SC-003  │ 请求参数校验                   │ MUST    │ 代码审查         │   │
│  │  SC-004  │ 响应格式统一                   │ MUST    │ 代码审查         │   │
│  │  SC-005  │ 错误码规范                     │ MUST    │ 代码审查         │   │
│  │  SC-006  │ trace_id传递                   │ MUST    │ 代码审查         │   │
│  │  SC-007  │ 超时设置合理                   │ MUST    │ 配置审查         │   │
│  │  SC-008  │ 重试机制                       │ SHOULD  │ 代码审查         │   │
│  │  SC-009  │ 熔断机制                       │ SHOULD  │ 代码审查         │   │
│  │  SC-010  │ 服务发现配置                   │ MUST    │ 配置审查         │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
└─────────────────────────────────────────────────────────────────────────────┘
