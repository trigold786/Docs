│  │    "filters": {"category": "数码"},  // 过滤条件                 │   │
│  │    "sort": "sales:desc",         // 排序                       │   │
│  │    "page": 1,                    // 页码                       │   │
│  │    "size": 20,                   // 每页数量                   │   │
│  │    "highlight": true              // 高亮                      │   │
│  │  }                                                                   │   │
│  │                                                                     │   │
│  │  推荐:                                                                │   │
│  │  POST /srs/v1/recommend                                             │   │
│  │  {                                                                   │   │
│  │    "scene": "HOME_FEED",         // 场景                       │   │
│  │    "user_id": "user-12345",     // 用户ID                     │   │
│  │    "context": {"page": 1},      // 上下文                     │   │
│  │    "count": 20,                  // 返回数量                   │   │
│  │    "filter": {"exclude_ids": [...]}  // 排除                 │   │
│  │  }                                                                   │   │
│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
│  【必选/可选】                                                               │
│                                                                             │
│  ┌─────────────────────────────────────────────────────────────────────┐   │
│  │                                                                     │   │
│  │  MUST：全文检索、高亮、过滤、排序                                    │   │
│  │  SHOULD：语义搜索、协同推荐、个性化推荐                              │   │
│  │  MAY：冷启动、实时推荐、探索与利用                                   │   │
│  │                                                                     │   │
│  └─────────────────────────────────────────────────────────────────────┘   │
│                                                                             │
└─────────────────────────────────────────────────────────────────────────────┘
```

