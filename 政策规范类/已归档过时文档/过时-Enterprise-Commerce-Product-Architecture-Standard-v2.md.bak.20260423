│   └── Dockerfile
├── frontend/                   # Vue 3前端
│   ├── src/
│   │   ├── api/              # API调用
│   │   ├── components/       # 组件库
│   │   ├── views/            # 页面
│   │   ├── stores/           # 状态管理
│   │   ├── i18n/              # 国际化
