│   │   ├── core/             # 核心配置
│   │   │   ├── config.py     # 应用配置
│   │   │   ├── security.py   # 安全工具
│   │   │   └── encryption.py # 加密工具
│   │   ├── models/           # 数据库模型
│   │   │   ├── user.py
│   │   │   └── api_key.py
│   │   ├── schemas/           # Pydantic模型
│   │   │   ├── auth.py
│   │   │   ├── key.py
│   │   │   └── common.py
│   │   ├── services/          # 业务逻辑
│   │   │   ├── auth_service.py
│   │   │   ├── key_service.py
│   │   │   └── notification_service.py
│   │   ├── db/                # 数据库连接
